# ==================================================
# 智能年鉴编纂系统 - 环境变量配置模板
# 复制此文件为 .env 并填写实际值
# ==================================================

# -------- Supabase 数据库配置 --------
# 方式一：Transaction Pooler（推荐，连接数少）
SPRING_DATASOURCE_URL=jdbc:postgresql://aws-0-ap-south-1.pooler.supabase.com:6543/postgres?prepareThreshold=0
SPRING_DATASOURCE_USERNAME=postgres.tqdosxaesqbwbhngvndj

# 方式二：直连（备用）
# SPRING_DATASOURCE_URL=jdbc:postgresql://db.tqdosxaesqbwbhngvndj.supabase.co:5432/postgres
# SPRING_DATASOURCE_USERNAME=postgres

# 数据库密码（在 Supabase Dashboard > Project Settings > Database > Database password 中找到）
SPRING_DATASOURCE_PASSWORD=your_supabase_database_password

# -------- JWT 签名密钥 --------
# 生成命令：openssl rand -base64 64
JWT_SECRET=Y2hyb25pY2xlLXNlY3JldC1rZXktZm9yLWp3dC10b2tlbi1nZW5lcmF0aW9uLTIwMjQ=

# -------- Supabase Storage（文件上传，可选）--------
SUPABASE_URL=https://tqdosxaesqbwbhngvndj.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
